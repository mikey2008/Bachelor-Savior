node_modules/
.DS_Store

# ── Secrets & Environment Variables ──────────────────────────────────────────
# NEVER commit API keys, tokens, or credentials to source control.
.env
.env.*
*.env
env.js
env.local

# Secret / config files that might accidentally contain keys
secrets.*
secret.*
config.local.*
api-keys.*
api_keys.*
credentials.*
*.key
*.pem
*.p12
*.pfx

# Log files (may contain sensitive request/response data)
*.log
logs/
npm-debug.log*

# SQLite database files (contains user data - never commit)
backend/db/*.db
backend/db/*.db-shm
backend/db/*.db-wal

# Test / scratch scripts
backend/scripts/test_*.js
